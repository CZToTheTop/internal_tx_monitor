{
  "name": "alchemy-chain-monitor",
  "version": "1.0.0",
  "description": "Monitor blockchain events and internal calls via Alchemy API webhooks",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "setup": "tsx src/setup.ts",
    "monitor": "tsx src/index.ts",
    "test:tx": "tsx src/test-tx.ts",
    "test:decode": "tsx scripts/test-decode.ts",
    "test:tx:webhook": "tsx scripts/test-tx-webhook.ts",
    "test:webhook": "bash scripts/test-webhook.sh",
    "test:webhook:local": "tsx scripts/test-webhook-signed.ts",
    "test": "vitest run",
    "poll": "tsx src/poll.ts",
    "setup:guide": "tsx scripts/setup-webhook-guide.ts"
  },
  "keywords": [
    "alchemy",
    "blockchain",
    "webhook",
    "monitor",
    "internal-calls"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "undici": "^7.0.0",
    "express": "^4.21.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
