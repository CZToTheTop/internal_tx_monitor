# Alchemy 链上监控 - 环境变量示例
# 复制为 .env 并填入实际值

# Alchemy Auth Token（用于 create-webhook API，不是 RPC API Key！）
# 获取方式: 需先在 Dashboard 手动创建至少一个 Webhook 后，Data → Webhooks 页面右上角才会出现 "AUTH TOKEN" 按钮
ALCHEMY_AUTH_TOKEN=your_alchemy_auth_token

# Webhook 签名验证密钥（可选）
# 推荐在 config.yaml 中为每个 target 配置 signing_key，则此处可不填
# 若不在 config 中配 signing_key，可在此填写，多个 key 用逗号分隔
# SIGNING_KEYS=whsec_xxxx,whsec_yyyy
# SIGNING_KEY=whsec_xxxx

# 测试时若尚未配置 SIGNING_KEYS，可临时设为 true 跳过签名验证（仅用于 Alchemy 端 Test Webhook）
# SKIP_SIGNATURE_VALIDATION=true

# 服务器配置
PORT=8080
HOST=0.0.0.0

# 可选：配置文件，默认 config.yaml
# CONFIG_PATH=./config.yaml
# 多项目多份规则（逗号/分号/换行分隔），与 CONFIG_PATH 二选一优先 CONFIG_PATHS
# CONFIG_PATHS=./config.project-a.yaml,./config.project-b.yaml

# Internal call 的 trace→tx 映射 + ABI 拉取：
# ETHERSCAN_API_KEY=your_etherscan_api_key

# 各链 RPC（填 ALCHEMY_API_KEY 即可，base 已内置；或填完整 URL 覆盖）：
# ALCHEMY_API_KEY=your_alchemy_api_key

# CoinGecko（vaultTransferErc20UsdAlert 等：按合约地址拉 USD 现货价；可不填则用公共 API）
# COINGECKO_API_KEY=  # Pro API 时填写，请求走 https://pro-api.coingecko.com

# 代理（Etherscan / CoinGecko 等外网请求走代理，如 Clash 默认 http://127.0.0.1:7890）：
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

# Telegram 通知（可选，配置后监控到事件会推送到 TG）
# 1. 找 @BotFather 创建 Bot，获取 token
# 2. 找 @userinfobot 获取你的 chat_id（或发消息给 Bot 后访问 https://api.telegram.org/bot<token>/getUpdates）
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=-1001234567890
